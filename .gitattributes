# Auto-detect text files and normalize line endings
* text=auto

# Force LF for common source files
*.sh text eol=lf
*.md text eol=lf
*.markdown text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.py text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Ensure package lockfiles are treated as text (but keep LF)
package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf
yarn.lock text eol=lf
